<Application xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mdix="http://materialdesigninxaml.net/winfx/xaml/themes"
             x:Class="Sheas_Cealer.App" x:ClassModifier="internal"
             Startup="App_OnStartup" DispatcherUnhandledException="App_DispatcherUnhandledException">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <mdix:BundledTheme BaseTheme="Inherit" PrimaryColor="Red" SecondaryColor="Red" />

                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.ToggleButton.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/Internal/MaterialDesignTheme.BaseThemeColors.xaml" />

                <ResourceDictionary Source="Rsces/Brushes/BaseBrush.xaml" />
                <ResourceDictionary Source="Rsces/Styles/BaseStyle.xaml" />
                <ResourceDictionary Source="Rsces/Tmpls/BaseTmpl.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>