<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:mdix="http://materialdesigninxaml.net/winfx/xaml/themes">
    <DataTemplate x:Key="CardGrip">
        <mdix:Card HorizontalAlignment="Left" Width="4" UniformCornerRadius="2"
                   Background="{DynamicResource MaterialDesign.Brush.Primary}" />
    </DataTemplate>

    <DataTemplate x:Key="PinIcon">
        <Viewbox Stretch="None">
            <mdix:PackIcon Kind="Pin"
                           RenderTransformOrigin="0.5 0.5">
                <mdix:PackIcon.RenderTransform>
                    <RotateTransform Angle="-45" />
                </mdix:PackIcon.RenderTransform>
            </mdix:PackIcon>
        </Viewbox>
    </DataTemplate>
</ResourceDictionary>