<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:mdix="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Style x:Key="MaterialDesignWindow" TargetType="Window"
           BasedOn="{StaticResource MaterialDesignWindow}">
        <Setter Property="FontFamily" Value="pack://application:,,,/MaterialDesignThemes.Wpf;component/Resources/Roboto/#Roboto, Microsoft YaHei UI" />
    </Style>

    <Style TargetType="mdix:DialogHost"
           BasedOn="{StaticResource {x:Type mdix:DialogHost}}">
        <Setter Property="DialogContentUniformCornerRadius" Value="8" />
        <Setter Property="CloseOnClickAway" Value="True" />
    </Style>

    <Style TargetType="Frame">
        <Setter Property="NavigationUIVisibility" Value="Hidden" />
    </Style>

    <Style TargetType="ScrollViewer"
           BasedOn="{StaticResource MaterialDesignScrollViewer}">
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="mdix:ScrollViewerAssist.IsAutoHideEnabled" Value="True" />
    </Style>

    <Style TargetType="ScrollBar"
           BasedOn="{StaticResource MaterialDesignScrollBarMinimal}">
        <Setter Property="Margin" Value="-15,0,-1,0" />
        <Setter Property="mdix:ScrollBarAssist.ThumbWidth" Value="4" />
        <Setter Property="mdix:ScrollBarAssist.ThumbCornerRadius" Value="2" />
    </Style>

    <Style TargetType="mdix:Ripple">
        <Setter Property="mdix:RippleAssist.ClipToBounds" Value="False" />
        <Setter Property="mdix:RippleAssist.Feedback"
                Value="{DynamicResource MaterialDesign.Brush.Button.Ripple}" />
        <Setter Property="mdix:RippleAssist.IsCentered" Value="True" />
    </Style>

    <Style TargetType="mdix:Card"
           BasedOn="{StaticResource MaterialDesignElevatedCard}">
        <Setter Property="mdix:ElevationAssist.Elevation" Value="Dp2" />
        <Setter Property="UniformCornerRadius" Value="8" />
        <Setter Property="Foreground"
                Value="{DynamicResource MaterialDesign.Brush.Foreground}" />
    </Style>

    <Style x:Key="TopBarCard" TargetType="mdix:Card"
           BasedOn="{StaticResource {x:Type mdix:Card}}">
        <Setter Property="UniformCornerRadius" Value="0" />
        <Setter Property="Height" Value="48" />
        <Setter Property="Background"
                Value="{DynamicResource MaterialDesign.Brush.AppBar.Background}" />
    </Style>

    <Style TargetType="mdix:PopupBox">
        <Setter Property="PlacementMode" Value="BottomAndAlignRightEdges" />
        <Setter Property="PopupUniformCornerRadius" Value="8" />
    </Style>

    <Style TargetType="TextBlock"
           BasedOn="{StaticResource MaterialDesignTextBlock}">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="mdix:TextBlockAssist.AutoToolTip" Value="True" />
    </Style>

    <Style x:Key="MaterialDesignSubtitle1TextBlock" TargetType="TextBlock"
           BasedOn="{StaticResource MaterialDesignSubtitle1TextBlock}">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="mdix:TextBlockAssist.AutoToolTip" Value="True" />
    </Style>

    <Style x:Key="MaterialDesignSubtitle2TextBlock" TargetType="TextBlock"
           BasedOn="{StaticResource MaterialDesignSubtitle2TextBlock}">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="mdix:TextBlockAssist.AutoToolTip" Value="True" />
    </Style>

    <Style x:Key="MaterialDesignCaptionTextBlock" TargetType="TextBlock"
           BasedOn="{StaticResource MaterialDesignCaptionTextBlock}">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="mdix:TextBlockAssist.AutoToolTip" Value="True" />
    </Style>

    <Style TargetType="Button"
           BasedOn="{StaticResource MaterialDesignRaisedButton}">
        <Setter Property="mdix:ButtonAssist.CornerRadius" Value="8" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="mdix:ButtonProgressAssist.IsIndeterminate" Value="True" />
    </Style>

    <Style x:Key="SmallImageButton" TargetType="Button"
           BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Width" Value="24" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style x:Key="MaterialDesignIconForegroundButton" TargetType="Button"
           BasedOn="{StaticResource MaterialDesignIconForegroundButton}">
        <Setter Property="Padding" Value="8" />
    </Style>

    <Style TargetType="ToggleButton" BasedOn="{StaticResource MaterialDesignSwitchToggleButton}">
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style x:Key="MaterialDesignHamburgerToggleButton" TargetType="ToggleButton"
           BasedOn="{StaticResource MaterialDesignHamburgerToggleButton}">
        <Setter Property="Height" Value="76" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style x:Key="ExpandToggleButton" TargetType="ToggleButton">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <mdix:Ripple>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CheckStates">
                                <VisualState x:Name="Checked">
                                    <Storyboard>
                                        <DoubleAnimation From="0" To="180" Duration="0:0:0.35"
                                                         Storyboard.TargetName="ExpandIconRotateTransform" Storyboard.TargetProperty="Angle">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Unchecked">
                                    <Storyboard>
                                        <DoubleAnimation From="180" To="0" Duration="0:0:0.35"
                                                         Storyboard.TargetName="ExpandIconRotateTransform" Storyboard.TargetProperty="Angle">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>

                        <Viewbox>
                            <mdix:PackIcon Kind="ExpandMore"
                                           RenderTransformOrigin="0.5 0.5" Margin="0,3"
                                           Foreground="{DynamicResource MaterialDesign.Brush.Foreground}">
                                <mdix:PackIcon.RenderTransform>
                                    <RotateTransform x:Name="ExpandIconRotateTransform" />
                                </mdix:PackIcon.RenderTransform>
                            </mdix:PackIcon>
                        </Viewbox>
                    </mdix:Ripple>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style TargetType="TextBox"
           BasedOn="{StaticResource MaterialDesignTextBox}">
        <Style.Triggers>
            <Trigger Property="Validation.HasError" Value="True">
                <Setter Property="Margin" Value="0,0,0,8" />
            </Trigger>
        </Style.Triggers>

        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="mdix:TextFieldAssist.HasClearButton" Value="True" />
        <Setter Property="mdix:ValidationAssist.HorizontalAlignment" Value="Right" />
        <Setter Property="mdix:ValidationAssist.Background" Value="Transparent" />
    </Style>

    <Style TargetType="ComboBox"
           BasedOn="{StaticResource MaterialDesignComboBox}">
        <Style.Triggers>
            <Trigger Property="Validation.HasError" Value="True">
                <Setter Property="Margin" Value="0,0,0,8" />
            </Trigger>
        </Style.Triggers>

        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="StaysOpenOnEdit" Value="True" />
        <Setter Property="mdix:ValidationAssist.HorizontalAlignment" Value="Right" />
        <Setter Property="mdix:ValidationAssist.Background" Value="Transparent" />
    </Style>

    <Style TargetType="Separator"
           BasedOn="{StaticResource MaterialDesignSeparator}">
        <Setter Property="Margin" Value="0" />
        <Setter Property="Height" Value="1" />
    </Style>
</ResourceDictionary>