<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:mdix="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:consts="clr-namespace:Sheas_Cealer.Consts"
      xmlns:models="clr-namespace:Sheas_Cealer.Models"
      x:Class="Sheas_Cealer.Pages.AboutPage" x:ClassModifier="internal" mc:Ignorable="d"
      Title="{x:Static consts:GlobalConst.AboutFlyoutItemTitle}">
    <ScrollViewer>
        <ItemsControl Margin="0,5,0,7">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="models:AboutInfo">
                    <mdix:Card Margin="12,5">
                        <Grid Margin="8,8,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="{Binding Title}"
                                       Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                       Grid.Column="0" Grid.Row="0" Margin="20,8,10,8" />
                            <TextBlock Text="{Binding Content}"
                                       Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                       Visibility="{Binding Content, StringFormat=Visible, TargetNullValue=Collapsed}"
                                       Grid.Column="1" Grid.Row="0" Margin="10,8,20,8" />
                            <TextBlock Text="{Binding Url}"
                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                       Visibility="{Binding Url, StringFormat=Visible, TargetNullValue=Collapsed}"
                                       Grid.ColumnSpan="2" Grid.Row="1" Margin="20,4" />
                            <StackPanel Orientation="Horizontal"
                                        Visibility="{Binding Url, StringFormat=Visible, TargetNullValue=Collapsed}"
                                        Grid.Column="1" Grid.Row="0" Margin="10,8,20,8">
                                <Button Content="{mdix:PackIcon ContentCopy}"
                                        ToolTip="{x:Static consts:AboutConst.CopyLinkButtonToolTip}"
                                        AutomationProperties.Name="{x:Static consts:AboutConst.CopyLinkButtonName}"
                                        Style="{StaticResource SmallImageButton}"
                                        HorizontalAlignment="Right" Margin="0,0,10,0"
                                        Click="CopyLinkButton_Clicked" />
                                <Button Content="{mdix:PackIcon OpenInNew}"
                                        ToolTip="{x:Static consts:AboutConst.GotoLinkButtonToolTip}"
                                        AutomationProperties.Name="{x:Static consts:AboutConst.GotoLinkButtonName}"
                                        Style="{StaticResource SmallImageButton}"
                                        HorizontalAlignment="Right" Margin="10,0,0,0"
                                        Click="GotoLinkButton_Clicked" />
                            </StackPanel>
                            <ContentPresenter ContentTemplate="{StaticResource CardGrip}"
                                              Grid.Column="0" Grid.RowSpan="2" />
                        </Grid>
                    </mdix:Card>
                </DataTemplate>
            </ItemsControl.ItemTemplate>

            <models:AboutInfo Title="{x:Static consts:AboutConst.DeveloperAboutInfoTitle}"
                              Content="{x:Static consts:AboutConst.DeveloperAboutInfoContent}" />
            <models:AboutInfo Title="{x:Static consts:AboutConst.VersionAboutInfoTitle}"
                              Content="{x:Static consts:GlobalConst.VersionAboutInfoContent}" />
            <models:AboutInfo Title="{x:Static consts:AboutConst.RepoAboutInfoTitle}"
                              Url="{x:Static consts:AboutConst.RepoAboutInfoUrl}" />
            <models:AboutInfo Title="{x:Static consts:AboutConst.DocsAboutInfoTitle}"
                              Url="{x:Static consts:AboutConst.DocsAboutInfoUrl}" />
            <models:AboutInfo Title="{x:Static consts:AboutConst.ContactAboutInfoTitle}"
                              Url="{x:Static consts:AboutConst.ContactAboutInfoUrl}" />
            <models:AboutInfo Title="{x:Static consts:AboutConst.IssueAboutInfoTitle}"
                              Url="{x:Static consts:AboutConst.IssueAboutInfoUrl}" />
            <models:AboutInfo Title="{x:Static consts:AboutConst.CenterAboutInfoTitle}"
                              Url="{x:Static consts:AboutConst.CenterAboutInfoUrl}" />
            <models:AboutInfo Title="{x:Static consts:AboutConst.BlogAboutInfoTitle}"
                              Url="{x:Static consts:AboutConst.BlogAboutInfoUrl}" />
            <models:AboutInfo Title="{x:Static consts:AboutConst.PolicyAboutInfoTitle}"
                              Url="{x:Static consts:AboutConst.PolicyAboutInfoUrl}" />
            <models:AboutInfo Title="{x:Static consts:AboutConst.EulaAboutInfoTitle}"
                              Url="{x:Static consts:AboutConst.EulaAboutInfoUrl}" />
        </ItemsControl>
    </ScrollViewer>
</Page>